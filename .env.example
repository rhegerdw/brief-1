# ===================
# Database (Required)
# ===================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===================
# AI/LLM (Required)
# ===================
OPENAI_API_KEY=sk-...

# ===================
# Research APIs (Required)
# ===================
SERPER_API_KEY=xxx

# ===================
# Calendar: Calendly
# ===================
CALENDLY_API_KEY=xxx
CALENDLY_SIGNING_SECRET=xxx

# ===================
# Calendar: Google (if using Google Calendar API)
# ===================
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://your-app.com/api/auth/callback/google

# ===================
# Calendar: Apps Script (if using Google Apps Script)
# ===================
APPS_SCRIPT_SECRET=xxx

# ===================
# Slack (Required for notifications)
# ===================
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=xxx
SLACK_BRIEF_CHANNEL_ID=C...
SLACK_CEO_USER_ID=U...

# ===================
# Optional Integrations
# ===================
FIRECRAWL_KEY=xxx
HARVEST_API_KEY=xxx
ANTHROPIC_API_KEY=xxx
GOOGLE_API_KEY=xxx

# ===================
# App Config
# ===================
PUBLIC_BASE_URL=https://brief.your-app.com
SLACK_ENABLED=true

# ===================
# Internal Domain Filter (for Google Calendar)
# Comma-separated list of domains to exclude from brief generation
# ===================
INTERNAL_DOMAINS=@your-company.com,@your-domain.com
